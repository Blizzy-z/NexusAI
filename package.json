{
  "name": "nexusai",
  "private": true,
  "version": "4.5.0",
  "type": "module",
  "main": "electron-main.cjs",
  "scripts": {
    "dev": "tsx server.ts",
    "start": "tsx server.ts",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "electron .",
    "electron:kill": "npx kill-port 3000 24678",
    "electron:fresh": "npx kill-port 3000 24678 && electron .",
    "electron:build": "npm run build && electron-builder",
    "backend": "cd backend && python server.py",
    "electron:prod": "npm run build && electron .",
    "serve:prod": "cross-env NODE_ENV=production tsx server.ts",
    "rebuild": "npm install && npm run build && electron .",
    "dev:server": "tsx server.ts",
    "build:prod": "cross-env NODE_ENV=production vite build"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "@monaco-editor/react": "^4.4.6",
    "monaco-editor": "^0.43.0",
    "clsx": "^2.1.1",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.7.0",
    "tailwind-merge": "^3.5.0",
    "three": "^0.183.2",
    "vite": "^6.2.0",
    "ws": "^8.18.1",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "docx": "^9.5.0",
    "jszip": "^3.10.1",
    "selfsigned": "^2.4.1"
  },
  "optionalDependencies": {
    "ssh2": "^1.17.0",
    "concurrently": "^9.0.0",
    "wait-on": "^8.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/three": "^0.174.0",
    "@types/ws": "^8.5.14",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "cross-env": "^7.0.3",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "com.nexusai.app",
    "productName": "NexusAI",
    "directories": {
      "output": "dist-electron"
    },
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "files": [
      "dist/**/*",
      "electron-main.cjs",
      "preload.js",
      "backend/**/*",
      "node_modules/**/*"
    ]
  }
}